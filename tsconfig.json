{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",                    // needed for path aliases
    "paths": {
      "@/*": ["./*"]                  // maps @/ to project root
    },
    "jsx": "react-jsx",               // for React 18+ JSX transform
    "skipLibCheck": true,             // avoid type errors in node_modules
    "noEmit": true                     // TS won't emit JS
  },
  "include": [
    "expo-env.d.ts",
    ".expo/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
, "supabase/functions/send-chat-notification/index.ts"  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}
