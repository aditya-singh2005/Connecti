{
  "expo": {
    "name": "Connecti",
    "slug": "connecti-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "connectiapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aditya.connectiapp",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "NSBluetoothAlwaysUsageDescription": "Connecti needs Bluetooth to detect nearby friends and enable proximity notifications.",
        "NSBluetoothPeripheralUsageDescription": "Connecti needs Bluetooth to connect with nearby friends and share presence.",
        "NSUserNotificationsUsageDescription": "We need to send you notifications when you receive messages or friends are nearby via Bluetooth."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.aditya.connectiapp",
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "edgeToEdgeEnabled": true,
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "VIBRATE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#2196F3"
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "Allow Connecti to connect to nearby Bluetooth devices to detect your friends."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9a700934-ca0a-4a5f-b4a5-27c670756c94"
      }
    }
  }
}