{
  "expo": {
    "name": "Connecti",
    "slug": "connecti-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "connectiapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.aditya.connectiapp",
      "buildNumber": "1.0.0",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification",
          "processing"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Connecti needs your location to notify you when you enter monitored zones, even when the app is closed or not in use.",
        "NSLocationWhenInUseUsageDescription": "Connecti needs your location to show nearby zones and connect with friends.",
        "NSLocationAlwaysUsageDescription": "Connecti needs background location to notify you when you enter zones, even when the app is closed.",
        "NSBluetoothAlwaysUsageDescription": "Connecti uses Bluetooth to detect nearby friends and send location updates.",
        "NSBluetoothPeripheralUsageDescription": "Connecti uses Bluetooth to connect with nearby friends.",
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.aditya.connectiapp.geofencing"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIApplicationExitsOnSuspend": false,
        "UIApplicationSupportsIndirectInputEvents": true
      },
      "entitlements": {
        "com.apple.developer.location-services": true,
        "com.apple.developer.location-services.background-mode": true
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.aditya.connectiapp",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "edgeToEdgeEnabled": true,
      "allowBackup": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "com.google.android.gms.permission.ACTIVITY_RECOGNITION"
      ],
      "intentFilters": [
        {
          "action": "MAIN",
          "category": [
            "LAUNCHER"
          ]
        }
      ],
      "foregroundService": {
        "notificationTitle": "Connecti Zone Monitoring",
        "notificationBody": "Monitoring geofence zones in background",
        "notificationColor": "#6366F1"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Connecti needs background location to detect when you enter zones, even when the app is closed.",
          "locationWhenInUsePermission": "Connecti needs your precise location to detect nearby zones accurately.",
          "locationAlwaysPermission": "Connecti needs always-on location access to notify you when you enter zones, even when the app is closed or killed.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "enableBackgroundLocationUpdates": true,
          "androidForegroundServiceNotificationTitle": "Connecti Zone Monitoring",
          "androidForegroundServiceNotificationBody": "Monitoring zone entries in background",
          "androidForegroundServiceNotificationColor": "#6366F1",
          "androidForegroundServiceNotificationChannelId": "geofence-monitoring",
          "androidForegroundServiceNotificationChannelName": "Zone Monitoring"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6366F1",
          "sounds": [],
          "defaultChannel": "geofence-alerts",
          "enableExactAlarms": true,
          "android": {
            "notificationChannelGroups": [
              {
                "id": "geofence_group",
                "name": "Geofence Alerts",
                "description": "Notifications for zone entries"
              }
            ],
            "notificationChannels": [
              {
                "id": "geofence-alerts",
                "name": "Geofence Zone Alerts",
                "description": "High priority notifications when you enter monitored zones",
                "importance": "MAX",
                "sound": "default",
                "vibrationPattern": [
                  0,
                  250,
                  250,
                  250
                ],
                "lightColor": "#FF0000",
                "lockscreenVisibility": "PUBLIC",
                "bypassDnd": true,
                "enableVibrate": true,
                "enableLights": true,
                "groupId": "geofence_group"
              },
              {
                "id": "geofence-monitoring",
                "name": "Zone Monitoring Service",
                "description": "Background service notification",
                "importance": "LOW",
                "sound": null,
                "vibrationPattern": null,
                "lightColor": "#6366F1",
                "lockscreenVisibility": "SECRET"
              }
            ]
          },
          "ios": {
            "allowsAnnouncements": true,
            "allowsDisplayInCarPlay": true,
            "shouldShowAlert": true,
            "shouldPlaySound": true,
            "shouldSetBadge": true
          }
        }
      ],
      "expo-task-manager",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow Connecti to connect to nearby Bluetooth devices to detect your friends.",
          "android": {
            "neverForLocation": false
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false,
            "extraProguardRules": "-keep class expo.modules.location.** { *; }",
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "ndkVersion": "27.1.12297006"
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9a700934-ca0a-4a5f-b4a5-27c670756c94"
      }
    },
    "owner": "aditya_singh2685",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9a700934-ca0a-4a5f-b4a5-27c670756c94",
      "fallbackToCacheTimeout": 0,
      "requestHeaders": {
        "expo-channel-name": "default"
      }
    }
  }
}